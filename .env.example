# Production Environment Variables (for Vercel deployment)
# Copy these to Vercel Project Settings → Environment Variables

# Database — use Vercel Postgres or Neon or Supabase
# Example: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/mess_settl?sslmode=require"

# Session secret — generate a random 32+ char string
# Run: openssl rand -hex 32
SESSION_SECRET="change-this-to-a-random-32-char-string-in-production"

# Firebase config (already in firebase.ts, but can override here)
# FIREBASE_API_KEY=""
# FIREBASE_AUTH_DOMAIN=""
# FIREBASE_PROJECT_ID=""
